# =====================================================================
# Template de variaveis de ambiente para DESENVOLVIMENTO LOCAL.
#
# Como usar:
#   1. Copie este arquivo para `backend/.env`
#         Windows (PowerShell): copy backend\.env.example backend\.env
#         Linux/Mac:            cp backend/.env.example backend/.env
#   2. Os valores abaixo ja estao prontos para o docker-compose deste repo.
#   3. NUNCA commite o arquivo .env (ele esta no .gitignore).
# =====================================================================

# --- Obrigatorio ---
# Chave usada para assinar tokens JWT. Em LOCAL pode ser qualquer string.
SECRET_KEY=troque-esta-string-por-qualquer-coisa-aleatoria-local

# --- Postgres local (servido pelo docker-compose.yml na raiz) ---
# O docker-compose.yml mapeia o Postgres em localhost:5433 (NAO 5432) para evitar
# conflito com Postgres nativo do Windows/Mac/Linux que muitos devs ja tem instalado.
# Por isso usamos DATABASE_URL com porta explicita abaixo, em vez do fallback DB_USER/DB_NAME
# (esse fallback monta uma string sem porta, usando 5432 default).
DATABASE_URL=postgresql://dogmau:dogmau@localhost:5433/dogmau_local

# Os campos abaixo nao sao lidos enquanto DATABASE_URL estiver setado, mas mantemos
# documentados para referencia (e caso queira comentar DATABASE_URL e usar localhost:5432).
DB_USER=dogmau
DB_PASS=dogmau
DB_NAME=dogmau_local

# CRITICO: manter "conexao_vazia" para nao ativar o modo Cloud SQL (socket Unix /cloudsql/...).
INSTANCE_CONNECTION_NAME=conexao_vazia

# --- Firebase (opcional em local) ---
# Deixe vazio: o login com Google fica desabilitado, mas o login por
# email/senha continua funcionando normalmente. Para habilitar Google Login,
# veja IMPLEMENTACAO_LOCAL.md (requer firebase-credentials.json).
FIREBASE_WEB_API_KEY=

# --- Tuning de desenvolvimento ---
DEBUG_LOG=true
ACCESS_TOKEN_EXPIRE_MINUTES=60
PORT=8080
